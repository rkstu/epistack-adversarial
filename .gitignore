# Python
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets (NEVER commit)
.env

# Runtime data (regenerated by pipeline — not needed in repo)
data/*
!data/sample/
*.jsonl
!data/sample/*.json

# IDE
.idea/
.vscode/
*.swp

# DEVELOPMENT.md is committed — it contains the full decision trail
# that another agent/developer needs to continue the work.
# It's marked as internal in its header but IS available in the repo.

# Private reference materials from competition organizers
docs/conor_infinitum/

# Internal strategy/competition files (not for public view)
PROJECT_CONTEXT.md
docs/SUBMISSION_GUIDE.md

# Everything else IS public and committed:
# - output/ (pre-built HTML for judges)
# - docs/ (submission, methodology, pipeline docs)
# - IMPLEMENTATION_PLAN.md (shows technical depth)
# - PROJECT_CONTEXT.md (competition context)
# - config.yaml, run_pipeline.py, src/, tests/, examples/, scripts/, static/
